<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Overwatch — Intelligence Briefs</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Georgia', serif;
            max-width: 720px;
            margin: 0 auto;
            padding: 2rem 1rem;
            color: #e0e0e0;
            background: #1a1a1a;
            line-height: 1.7;
        }
        header {
            border-bottom: 2px solid #e0e0e0;
            padding-bottom: 1rem;
            margin-bottom: 2rem;
        }
        header h1 {
            font-size: 1.6rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            color: #f0f0f0;
        }
        header .meta {
            font-size: 0.85rem;
            color: #999;
            margin-top: 0.3rem;
        }
        .topic-section {
            margin-bottom: 2.5rem;
        }
        .topic-section h2 {
            font-size: 1.2rem;
            color: #f0f0f0;
            margin-bottom: 0.8rem;
            border-bottom: 1px solid #333;
            padding-bottom: 0.4rem;
        }
        .brief-list {
            list-style: none;
            padding: 0;
        }
        .brief-list li {
            margin-bottom: 0.4rem;
        }
        .brief-list a {
            color: #5cb8d6;
            text-decoration: none;
            font-size: 0.95rem;
        }
        .brief-list a:hover {
            color: #7ecde8;
        }
        .byline {
            color: #999;
            font-size: 0.85rem;
        }
        footer {
            border-top: 1px solid #333;
            margin-top: 2rem;
            padding-top: 1rem;
            font-size: 0.8rem;
            color: #777;
        }
    </style>
</head>
<body>
    <header>
        <h1>Overwatch</h1>
        <div class="meta">Intelligence Briefs</div>
    </header>
    {% for topic in topics %}
    <div class="topic-section">
        <h2>{{ topic.name }}</h2>
        <ul class="brief-list">
            {% for brief in topic.briefs %}
            <li><a href="{{ brief.path }}">{{ brief.date }}</a>{% if brief.byline %} <span class="byline">— {{ brief.byline }}</span>{% endif %}</li>
            {% endfor %}
        </ul>
    </div>
    {% endfor %}
    <footer>
        Generated by Overwatch
    </footer>
</body>
</html>
