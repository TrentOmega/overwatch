# Optional: override Claude model (defaults to your CLI's configured model)
# OVERWATCH_MODEL=claude-opus-4-6

# Optional: YouTube cookies file for bypassing IP blocks
# Export from browser: yt-dlp --cookies-from-browser chrome --cookies cookies.txt --skip-download "https://youtube.com"
# Or use a browser extension like "Get cookies.txt LOCALLY"
# YOUTUBE_COOKIES_FILE=./cookies.txt

# Optional: web search backend (pick one)
# SEARXNG_URL=http://localhost:8080
# BRAVE_SEARCH_API_KEY=your-key
# SERPER_API_KEY=your-key
